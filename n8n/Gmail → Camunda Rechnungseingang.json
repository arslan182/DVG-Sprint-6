    },
    {
      "parameters": {
        "jsCode": "// Prüfen ob ein PDF-Anhang vorhanden ist\nconst item = $input.first();\n\nconst attachmentKeys = Object.keys(item.binary || {});\nconst pdfKey = attachmentKeys.find(k => {\n  const mime = item.binary[k]?.mimeType || '';\n  const name = item.binary[k]?.fileName || '';\n  return mime === 'application/pdf' || name.toLowerCase().endsWith('.pdf');\n});\n\nif (!pdfKey) {\n  return [{ json: { anhang_vorhanden: false, grund: 'Kein PDF-Anhang gefunden' } }];\n}\n\nconst attachment = item.binary[pdfKey];\nconst absender = item.json?.from || 'unbekannt';\nconst betreff = item.json?.subject || 'Rechnung';\nconst timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\nconst dateiname = (attachment.fileName || 'rechnung.pdf').replace(/[^a-zA-Z0-9._-]/g, '_');\nconst finaler_dateiname = `${timestamp}_${dateiname}`;\n\nreturn [{\n  json: {\n    anhang_vorhanden: true,\n    pdf_key: pdfKey,\n    dateiname,\n    finaler_dateiname,\n    absender,\n    betreff\n  },\n  binary: item.binary\n}];"
      },
      "id": "88cbf08a-c0d4-45b1-9289-d6efe65fdaf5",
      "name": "PDF-Anhang prüfen",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        16,
        192
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 1
          },
          "conditions": [
            {
              "id": "check-pdf",
              "leftValue": "={{ $json.anhang_vorhanden }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "7ecce287-ce00-4c60-98d1-f38d51aa645b",
