      "id": "27a9ecc0-c9f9-4be2-ad38-8d525c842c07",
      "name": "PDF zu Google Drive hochladen",
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [
        496,
        64
      ],
      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "egGWq2SMBB07jqs2",
          "name": "Google Drive account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Google Drive Link und File-ID aus der Upload-Antwort extrahieren\nconst item = $('PDF zu Google Drive hochladen').first();\nconst fileId = item.json?.id;\nconst fileName = item.json?.name;\n\nif (!fileId) throw new Error('Google Drive Upload fehlgeschlagen – keine File-ID erhalten');\n\nconst driveUrl = `https://drive.usercontent.google.com/download?id=${fileId}&export=download&authuser=0`;\n\nconsole.log(`[Gmail-Workflow] PDF in Google Drive: ${fileName} (${fileId})`);\n\nreturn [{\n  json: {\n    drive_file_id: fileId,\n    drive_url: driveUrl,\n    dateiname: fileName,\n    absender: $('PDF-Anhang prüfen').item.json.absender,\n    betreff: $('PDF-Anhang prüfen').item.json.betreff\n  }\n}];"
      },
      "id": "e5766223-6705-4015-ae67-8c35c9f70fcb",
      "name": "Drive-Link aufbereiten",
